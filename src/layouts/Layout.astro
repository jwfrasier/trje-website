---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description: string;
  ogTitle?: string;
  ogDescription?: string;
  ogUrl: string;
  ogImage?: string;
  canonicalUrl: string;
  activeRoute?: "home" | "episodes" | "about" | "wall" | "contact" | null;
}

const {
  title,
  description,
  ogTitle,
  ogDescription,
  ogUrl,
  ogImage = "/brand/og-card.svg",
  canonicalUrl,
  activeRoute = null,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark light" />
    <meta name="theme-color" content="#1c1410" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={ogTitle ?? title} />
    <meta property="og:description" content={ogDescription ?? description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={ogUrl} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
    <!--
      Analytics stub. Plausible is privacy-first (no cookies, no banner,
      ~1KB script) and the right fit for TRJE. To enable: create a Plausible
      site for therealjesusexperience.com, then uncomment the script below.
      No other code change is required.
    -->
    <!-- <script defer data-domain="therealjesusexperience.com" src="https://plausible.io/js/script.js"></script> -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Oswald:wght@300;400;500;600;700&family=Karla:ital,wght@0,400;0,500;0,600;1,500&display=swap"
    />
    <script is:inline>
      // Add the .has-anim class before paint so animated items render hidden,
      // unless the visitor prefers reduced motion or JS is disabled.
      // Defensive fallback: if GSAP fails to load/run, remove .has-anim after
      // 3500ms so CSS resting state (opacity:1) becomes the final state.
      (function () {
        try {
          if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
            document.documentElement.classList.add('has-anim');
            setTimeout(function () {
              document.documentElement.classList.remove('has-anim');
            }, 3500);
          }
        } catch (_) { /* no-op */ }
      })();
    </script>
  </head>
  <body>
    <a href="#main" class="skip">Skip to content</a>

    <Nav activeRoute={activeRoute} />

    <main id="main"><slot /></main>

    <Footer />

    <script is:inline>
      (function () {
        const nav = document.getElementById('site-nav');
        const toggle = document.getElementById('nav-toggle');
        const menu = document.getElementById('nav-menu');

        if (nav) {
          const setScrolled = () => {
            nav.dataset.scrolled = window.scrollY > 4 ? 'true' : 'false';
          };
          setScrolled();
          window.addEventListener('scroll', setScrolled, { passive: true });
        }

        if (toggle && menu) {
          const mobileMQ = window.matchMedia('(max-width: 720px)');
          let savedFocus = null;
          let keydownHandler = null;

          const getFocusable = () =>
            Array.from(
              menu.querySelectorAll('a[href], button:not([disabled])')
            ).filter((el) => !el.hasAttribute('disabled'));

          const applyClosedState = () => {
            // Only inert/hide the sheet at mobile widths; desktop nav must
            // remain tab-reachable.
            if (mobileMQ.matches) {
              menu.setAttribute('inert', '');
              menu.setAttribute('aria-hidden', 'true');
            } else {
              menu.removeAttribute('inert');
              menu.removeAttribute('aria-hidden');
            }
          };

          const applyOpenState = () => {
            menu.removeAttribute('inert');
            menu.setAttribute('aria-hidden', 'false');
          };

          const onKeydown = (e) => {
            if (e.key === 'Escape') {
              e.preventDefault();
              closeMenu();
              return;
            }
            if (e.key !== 'Tab') return;
            const focusables = getFocusable();
            if (focusables.length === 0) return;
            const first = focusables[0];
            const last = focusables[focusables.length - 1];
            const active = document.activeElement;
            if (e.shiftKey) {
              if (active === first || !menu.contains(active)) {
                e.preventDefault();
                last.focus();
              }
            } else {
              if (active === last) {
                e.preventDefault();
                first.focus();
              }
            }
          };

          const openMenu = () => {
            savedFocus = document.activeElement;
            menu.dataset.open = 'true';
            toggle.setAttribute('aria-expanded', 'true');
            applyOpenState();
            const focusables = getFocusable();
            if (focusables.length) focusables[0].focus();
            keydownHandler = onKeydown;
            document.addEventListener('keydown', keydownHandler);
          };

          const closeMenu = () => {
            const wasOpen = menu.dataset.open === 'true';
            menu.dataset.open = 'false';
            toggle.setAttribute('aria-expanded', 'false');
            applyClosedState();
            if (keydownHandler) {
              document.removeEventListener('keydown', keydownHandler);
              keydownHandler = null;
            }
            if (wasOpen) {
              const target =
                savedFocus && document.contains(savedFocus) ? savedFocus : toggle;
              if (target && typeof target.focus === 'function') target.focus();
              savedFocus = null;
            }
          };

          // Initial state: closed.
          applyClosedState();

          toggle.addEventListener('click', () => {
            const open = menu.dataset.open === 'true';
            if (open) closeMenu();
            else openMenu();
          });
          menu.addEventListener('click', (e) => {
            if (e.target && e.target.tagName === 'A') {
              closeMenu();
            }
          });

          // React to viewport mode flips.
          const onModeChange = () => {
            if (!mobileMQ.matches) {
              // Desktop: ensure sheet is closed and not inert.
              if (menu.dataset.open === 'true') closeMenu();
              menu.removeAttribute('inert');
              menu.removeAttribute('aria-hidden');
            } else {
              // Mobile: if closed, apply inert/aria-hidden.
              if (menu.dataset.open !== 'true') applyClosedState();
            }
          };
          if (mobileMQ.addEventListener) {
            mobileMQ.addEventListener('change', onModeChange);
          } else if (mobileMQ.addListener) {
            mobileMQ.addListener(onModeChange);
          }
        }

        const frame = document.getElementById('episode-frame');
        if (frame) {
          const iframe = frame.querySelector('iframe');
          let loaded = false;
          if (iframe) {
            iframe.addEventListener('load', () => { loaded = true; });
            setTimeout(() => {
              if (!loaded) frame.dataset.fallback = 'true';
            }, 4000);
          }
        }
      })();
    </script>
  </body>
</html>
